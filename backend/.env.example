# === Telegram ===
BOT_TOKEN=123456:ABC-DEF1234ghIkl-zyx57W2v1u123ew11
WEBAPP_URL=https://your-domain.com

# === AI Providers ===
# GigaChat (Sber) — тексты + изображения (fallback)
GIGACHAT_CLIENT_ID=your_client_id
GIGACHAT_CLIENT_SECRET=your_client_secret

# YandexGPT + YandexART — опционально
YANDEX_API_KEY=your_api_key
YANDEX_FOLDER_ID=your_folder_id

# Провайдер текста: gigachat | yandexgpt | mock
AI_PROVIDER=gigachat

# Провайдер изображений: yandexart | gigachat | auto
# auto = пробует YandexART → если нет ключей, GigaChat
IMAGE_PROVIDER=auto

# === Server ===
PORT=3000
NODE_ENV=production

# === Лимиты ===
FREE_DAILY_LIMIT=14

# === Безопасность ===
# Для GigaChat (самоподписанные сертификаты Sber)
# NODE_TLS_REJECT_UNAUTHORIZED=0
